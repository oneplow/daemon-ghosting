# Daemon
DAEMON_ID=daemon-01
NODE_NAME=SG-1
API_ENDPOINT=http://localhost:3000
WS_ENDPOINT=ws://localhost:3000
DAEMON_AUTH_TOKEN=ghd_dev_token
DAEMON_PORT=8443
DAEMON_HOST=0.0.0.0

# Docker
DOCKER_SOCKET=/var/run/docker.sock
DATA_DIR=/opt/ghosting/data
CONTAINER_PREFIX=gs-

# Intervals (ms)
HEARTBEAT_INTERVAL=30000
METRICS_INTERVAL=10000

# FRP (optional)
FRP_ENABLED=false
FRP_SERVER_ADDR=0.0.0.0
FRP_SERVER_PORT=7000
FRP_TOKEN=
